generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Plan {
  plan_id            Int            @id @default(autoincrement())
  plan_name          String         @unique
  max_users          Int
  description        String?
  next_renewal_date  DateTime?
  crea1ted_at        DateTime       @default(now())
  updated_at         DateTime       @updatedAt
  has_ai             Boolean
  has_exports        Boolean
  has_reports        Boolean
  price_monthly      Float
  price_yearly       Float
  cardnet_product_id String?
  subscriptions      Subscription[]

  @@map("plans")
}

model Subscription {
  subs_id                 Int       @id @default(autoincrement())
  subs_status             String    @default("trial")
  start_date              DateTime  @default(now())
  end_date                DateTime?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt
  plan_id                 Int
  comp_id                 Int       @unique
  cardnet_customer_id     String?   @unique(map: "subscriptions_cardnet_customer_id_key")
  cardnet_subscription_id String?   @unique(map: "subscriptions_cardnet_subscription_id_key")
  trial_ends_at           DateTime?
  company                 Company   @relation(fields: [comp_id], references: [comp_id], onDelete: Cascade)
  plan                    Plan      @relation(fields: [plan_id], references: [plan_id], onDelete: Cascade)

  @@map("subscriptions")
}

model Company {
  comp_id      Int           @id @default(autoincrement())
  comp_name    String
  comp_email   String        @unique
  comp_phone   String?
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  status       String        @default("active")
  clients      Client[]
  expenses     Expense[]
  inventory    Inventory[]
  products     Product[]
  purchases    Purchase[]
  sales        Sales[]
  subscription Subscription?
  users        User[]

  @@map("companies")
}

model User {
  user_id       Int        @id @default(autoincrement())
  user_name     String
  user_email    String
  user_password String
  user_role     String
  status        String     @default("active")
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  comp_id       Int
  expenses      Expense[]
  purchases     Purchase[]
  sales         Sales[]
  company       Company    @relation(fields: [comp_id], references: [comp_id], onDelete: Cascade)

  @@unique([user_email, comp_id])
  @@map("users")
}

model Product {
  product_id          Int              @id @default(autoincrement())
  product_name        String
  product_description String?
  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt
  comp_id             Int
  external_product_id String?
  expenses            Expense[]
  inventory           Inventory?
  hashtags            ProductHashtag[]
  company             Company          @relation(fields: [comp_id], references: [comp_id], onDelete: Cascade)
  purchase_details    PurchaseDetail[]

  @@unique([product_name, comp_id])
  @@map("products")
}

model Hashtag {
  hashtag_id   Int              @id @default(autoincrement())
  hashtag_name String           @unique
  created_at   DateTime         @default(now())
  products     ProductHashtag[]

  @@map("hashtags")
}

model ProductHashtag {
  prod_hash_id Int     @id @default(autoincrement())
  product_id   Int
  hashtag_id   Int
  hashtag      Hashtag @relation(fields: [hashtag_id], references: [hashtag_id], onDelete: Cascade)
  product      Product @relation(fields: [product_id], references: [product_id], onDelete: Cascade)

  @@unique([product_id, hashtag_id])
  @@map("product_hashtags")
}

model Purchase {
  purch_id              Int              @id @default(autoincrement())
  alt_purch_name        String?
  alt_purch_description String?
  purch_quantity        Int?
  purch_currency        String?
  purch_price           Float?
  dop_price             Float?
  added_to_inventory    Boolean          @default(false)
  created_at            DateTime         @default(now())
  updated_at            DateTime         @updatedAt
  comp_id               Int
  user_id               Int
  expenses              Expense[]
  purchase_details      PurchaseDetail[]
  company               Company          @relation(fields: [comp_id], references: [comp_id], onDelete: Cascade)
  user                  User             @relation(fields: [user_id], references: [user_id])

  @@map("purchases")
}

model PurchaseDetail {
  purch_detail_id Int      @id @default(autoincrement())
  quantity        Int
  unit_price      Float
  drop_price      Float?
  created_at      DateTime @default(now())
  product_id      Int
  purch_id        Int
  product         Product  @relation(fields: [product_id], references: [product_id])
  purchase        Purchase @relation(fields: [purch_id], references: [purch_id], onDelete: Cascade)

  @@map("purchase_details")
}

model Inventory {
  inv_id                 Int          @id @default(autoincrement())
  stock_quantity         Int
  average_purchase_price Float
  last_purchase_price    Float
  sale_price             Float
  status                 String       @default("available")
  created_at             DateTime     @default(now())
  updated_at             DateTime     @updatedAt
  comp_id                Int
  product_id             Int          @unique
  expenses               Expense[]
  company                Company      @relation(fields: [comp_id], references: [comp_id], onDelete: Cascade)
  product                Product      @relation(fields: [product_id], references: [product_id], onDelete: Cascade)
  sale_details           SaleDetail[]

  @@map("inventory")
}

model Sales {
  sales_id       Int           @id @default(autoincrement())
  total          Float
  paid_amount    Float         @default(0)
  pending_amount Float         @default(0)
  payment_status String        @default("pending")
  sale_type      String        @default("cash")
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt
  comp_id        Int
  user_id        Int
  client_id      Int?
  debt_payments  DebtPayment[]
  sale_details   SaleDetail[]
  client         Client?       @relation(fields: [client_id], references: [client_id])
  company        Company       @relation(fields: [comp_id], references: [comp_id], onDelete: Cascade)
  user           User          @relation(fields: [user_id], references: [user_id])

  @@map("sales")
}

model SaleDetail {
  sales_detail_id Int       @id @default(autoincrement())
  quantity        Int
  unit_price      Float
  sale_price      Float
  subtotal        Float
  created_at      DateTime  @default(now())
  inv_id          Int
  sales_id        Int
  inventory       Inventory @relation(fields: [inv_id], references: [inv_id])
  sales           Sales     @relation(fields: [sales_id], references: [sales_id], onDelete: Cascade)

  @@map("sale_details")
}

model Client {
  client_id     Int           @id @default(autoincrement())
  full_name     String
  phone         String?
  document      String?
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  comp_id       Int
  company       Company       @relation(fields: [comp_id], references: [comp_id], onDelete: Cascade)
  debt_payments DebtPayment[]
  sales         Sales[]

  @@unique([document, comp_id])
  @@map("clients")
}

model DebtPayment {
  pay_id           Int      @id @default(autoincrement())
  amount           Float
  previous_balance Float
  new_balance      Float
  pay_method       String?
  created_at       DateTime @default(now())
  client_id        Int
  sales_id         Int
  client           Client   @relation(fields: [client_id], references: [client_id], onDelete: Cascade)
  sales            Sales    @relation(fields: [sales_id], references: [sales_id], onDelete: Cascade)

  @@map("debt_payments")
}

model Expense {
  exp_id          Int        @id @default(autoincrement())
  exp_title       String
  exp_description String?
  exp_type        String
  quantity        Int?
  exp_amount      Float
  exp_currency    String
  exp_price       Float?
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt
  comp_id         Int
  user_id         Int
  purch_id        Int?
  inv_id          Int?
  product_id      Int?
  company         Company    @relation(fields: [comp_id], references: [comp_id], onDelete: Cascade)
  inventory       Inventory? @relation(fields: [inv_id], references: [inv_id])
  product         Product?   @relation(fields: [product_id], references: [product_id])
  purchase        Purchase?  @relation(fields: [purch_id], references: [purch_id])
  user            User       @relation(fields: [user_id], references: [user_id])

  @@map("expenses")
}
